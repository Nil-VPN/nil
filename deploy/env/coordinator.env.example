# ---------------------------------------------------------------------------
# nil-coordinator (Control plane) — production environment template
# ---------------------------------------------------------------------------
# Copy to deploy/env/coordinator.env and fill in the TODO values. Run this stack
# on a host/account that is SEPARATE from the Portal (PD-4): the Coordinator is a
# different trust domain. It is the Privacy Pass VERIFIER (public key only — it can
# never mint a token), the trust-split path selector, and the measurement registry.
# It never sees account identity, payment, or a packet.
#
# nil-coordinator serves PLAIN HTTP; the Caddy reverse proxy in
# compose.coordinator.yaml terminates TLS for ctrl.<domain>. The coordinator is
# never exposed directly.
# ===========================================================================

# --- Immutable external runtime image -------------------------------------
# The NIL release workflow does not yet publish an approved Caddy digest. Resolve it for the
# deployment platform, verify it, and record it in the signed release manifest. This fail-closed
# placeholder deliberately prevents a mutable-tag deployment.
CADDY_IMAGE=caddy@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST

# --- Public hostname (proxy / Let's Encrypt) ------------------------------
# TODO: the public FQDN clients hit, e.g. ctrl.nilvpn.example. A/AAAA DNS for it
#       must already point at this host before first boot, or ACME will fail.
CTRL_PUBLIC_HOST=ctrl.example.com
# TODO: contact email for the Let's Encrypt account (expiry notices only).
ACME_EMAIL=admin@example.com

# --- Coordinator HTTP bind (behind the proxy) ------------------------------
# Defaults to 0.0.0.0:9090 inside compose so the proxy can reach it.
NW_COORDINATOR_ADDR=0.0.0.0:9090

# --- Authenticated reverse-proxy attribution -------------------------------
# Caddy is assigned this fixed private address. The Coordinator rejects the reserved client-IP
# header from every other direct peer and release startup refuses an absent/noncanonical value.
# Change the whole subnet/IP set together if it conflicts with the deployment host network.
COORDINATOR_NETWORK_SUBNET=172.31.10.0/24
NW_TRUSTED_PROXY_IP=172.31.10.2
COORDINATOR_BACKEND_IP=172.31.10.3

# --- Hops per path ---------------------------------------------------------
# Production/release builds require at least two hops. Three supplies explicit
# entry/middle/exit separation and needs three independently operated nodes.
NW_PATH_HOPS=3

# --- Privacy Pass verifier: the Portal's PUBLIC key ONLY -------------------
# Comma-separated DER public-key hex. This is the `token_pubkey` the Portal logged
# on first boot (also at https://api.<domain>/v1/tokens/pubkey). The PRIVATE issuer
# key NEVER leaves the Portal — keeping verify and issue split is the whole point.
# TODO: paste the Portal's token_pubkey hex.
NW_TOKEN_PUBKEY=REPLACE_WITH_PORTAL_TOKEN_PUBKEY_HEX
# Absolute Unix timestamp at which legacy no-expiry token messages stop being accepted. Set this
# to the migration deadline (release time + 30 days); v2 tokens are bounded to 24 hours.
NW_LEGACY_TOKEN_CUTOFF=REPLACE_WITH_MIGRATION_CUTOFF_UNIX

# --- Durable anonymous redemption ledger -----------------------------------
# Path INSIDE the container (compose maps it to a named volume). Durable so a
# restart cannot re-accept an already-spent token (closes the double-spend window).
NW_NULLIFIER_PATH=/var/lib/nil-coordinator/nullifiers.log
# For a multi-replica Postgres deployment, remove NW_NULLIFIER_PATH/NW_NULLIFIER_DIR and set
# NW_NULLIFIER_PG_URL in a build with the `postgres` feature. The service refuses two authorities.

# The authoritative ledger stores the first PathResponse only as AES-256-GCM ciphertext until its
# grants expire. Generate an independent raw 32-byte key (never reuse the grant-signing seed):
#   cargo run -p nil-coordinator --release -- \
#     redemption-keygen deploy/secrets/redemption_result_key.bin
# Then `chown 10002:10002` and `chmod 0400` it. Every replica sharing one Postgres ledger needs the
# same file; rotation before all live replay ciphertext expires makes those retries fail closed.
NW_REDEMPTION_RESULT_KEY_FILE=/etc/nil/redemption_result_key.bin

# --- Node tunnel grants (MOST SENSITIVE COORDINATOR SECRET) ----------------
# NWG2 grants are Ed25519-signed and audience-bound to a registry node id. This
# file contains exactly one hex-encoded 32-byte Ed25519 seed. Generate it in the
# Coordinator trust domain, keep it out of git, and never copy it to a node:
#   cargo run -p nil-coordinator --release -- \
#     grant-keygen deploy/secrets/grant_signing_seed.hex
# The command creates a new owner-only file and prints only the corresponding public key and key
# ID. Install that public key in each node's verifier ring. The production image runs as uid/gid
# 10002, so a Linux bind mount must be transferred to that service identity before startup:
#   sudo chown 10002:10002 deploy/secrets/grant_signing_seed.hex
#   sudo chmod 0400 deploy/secrets/grant_signing_seed.hex
# (`grant-public-key PATH` should be run before that transfer, or later with equivalent privileged
# access.) `NW_GRANT_SIGNING_KEY` is a debug-only alternative and must not appear in production.
NW_GRANT_SIGNING_KEY_FILE=/etc/nil/grant_signing_seed.hex
# Realm prevents a valid grant from being replayed across deployments. Change it
# deliberately for a new security domain and configure the identical value on
# every node in this registry.
NW_GRANT_REALM=nil-production-v1
# Grants are intentionally short-lived. Five minutes covers redemption + dial
# while keeping stolen grants low-value.
NW_GRANT_TTL_SECS=300

# --- Node registry (JSON FILE path inside the container) -------------------
# compose mounts ./coordinator/registry.json read-only here. It is an ARRAY of
# {id, host, port, tee, measurement, tls_spki_sha256, operator, jurisdiction, role, wg_pub?,
#  min_tcb_sevsnp?, tdx_policy?, transparency_log_key}. Release builds require a transparency key
#  on every node and min_tcb_sevsnp on every SEV-SNP node. For SEV-SNP, measurement is the exact
#  48-byte launch measurement and tdx_policy is forbidden. For TDX, measurement is NIL's composite
#  SHA-384 identity (not raw MRTD), min_tcb_sevsnp is forbidden, and the complete exact tdx_policy
#  is mandatory; generate only a
#  review candidate with `cargo run -p nil-attest --example tdx_policy -- QUOTE COLLATERAL_JSON`.
# Release paths currently require every host to be the node's canonical IPv4 listener AND the
# source IPv4 observed by its successor, with port 443, because NWG2 signs both path neighbors.
# Every numeric zero in registry.json.example's TCB object is a schema placeholder, not an approved
# production floor; replace it from reviewed platform collateral before using the registry.
# `id` is the grant audience and must exactly match that node's NW_NODE_ID. Each
# node pins its own reviewed SEV-SNP launch measurement or complete TDX identity (the placeholder
# example must never reach production).
NW_NODE_REGISTRY=/etc/nil/registry.json

# --- Logging ----------------------------------------------------------------
# The checked-in Caddyfile disables HTTP access logs and Compose discards Caddy operational output.
# Coordinator operational output is bounded by Compose but is not assumed anonymous. Raise
# verbosity only under a time-bounded incident procedure with explicit retention and deletion.
RUST_LOG=info,nil_coordinator=info
