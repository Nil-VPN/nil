# ---------------------------------------------------------------------------
# nil-portal — STAGING environment template (local-only; never committed)
# ---------------------------------------------------------------------------
# Staging is a FAITHFUL mini-prod: same nil-portal:prod image, real attestation on the staging CVM,
# real grants. It differs from production ONLY in payment NETWORK (Monero stagenet + Paddle sandbox
# — real code paths, valueless test coins) and hostnames. It deliberately sets NO dev/mock flags
# (NW_MOCK_PAID / NW_ALLOW_UNGRANTED / NW_ALLOW_DEV_FALLBACKS) so it exercises the real rails — and
# so deploy.sh's fail-closed prod-safety guard would still pass on it.
#
# Copy to env/portal.env ON THE STAGING HOST and fill the TODOs. Start from env/portal.env.example
# for the full field docs; below are ONLY the staging-specific values.
# ===========================================================================

# Immutable, staging-approved external images. Replace with verified platform manifest digests.
CADDY_IMAGE=caddy@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST
MONERO_WALLET_RPC_IMAGE=ghcr.io/sethforprivacy/simple-monero-wallet-rpc@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST

# --- Staging public hostname (Caddy ACME) ---------------------------------
PORTAL_PUBLIC_HOST=api-staging.nilvpn.net
ACME_EMAIL=admin@nilvpn.net

NW_PORTAL_ADDR=0.0.0.0:8080
PORTAL_NETWORK_SUBNET=172.30.20.0/24
NW_TRUSTED_PROXY_IP=172.30.20.2
PORTAL_BACKEND_IP=172.30.20.3
NW_PORTAL_STORE=/var/lib/nil-portal/accounts.json
NW_PORTAL_RESULT_KEY_FILE=/etc/nil/portal_result_key.bin
NW_ISSUED_PATH=/var/lib/nil-portal/issued.log
# Set to 1 only after every older staging Portal is stopped and issued.log is preserved.
NW_ISSUANCE_STOP_THE_WORLD_CUTOVER=REPLACE_WITH_1_AFTER_ALL_OLD_PORTALS_ARE_STOPPED
NW_PENDING_PATH=/var/lib/nil-portal/pending.log
NW_SUB_BINDINGS_PATH=/var/lib/nil-portal/subscription-bindings.log
NW_CHECKOUT_TTL_SECS=3600
NW_CHECKOUT_RATE_MAX=30
NW_PENDING_MAX_ENTRIES=100000
# Read-only upgrade fence; still required and must already exist (an existing old file, or an
# explicitly provisioned empty owner-readable file on a brand-new deployment). See
# portal.env.example for the precise T0 + max rollout TTL + 600s retirement eligibility rule. New
# activations live in NW_PORTAL_STORE.
NW_SUB_ACTIVATED_PATH=/var/lib/nil-portal/subscription-activated-legacy.log

# HSM issuer: provision a DISTINCT non-extractable staging key and PIN (never reuse production).
NW_TOKEN_HSM_KEY_LABEL=nil-issuer-staging
NW_TOKEN_HSM_SLOT=REPLACE_WITH_NUMERIC_STAGING_HSM_SLOT_ID
PORTAL_PKCS11_MODULE_FILE=/absolute/path/to/approved/staging-vendor-pkcs11.so
PORTAL_HSM_PIN_FILE=./secrets/portal_hsm_pin-staging

# --- Monero STAGENET (valueless test coins; real watcher path) -------------
# Run monerod + monero-wallet-rpc with --stagenet; watch-only wallet on a stagenet address.
# Default stagenet wallet-rpc port here is 38082 (loopback). Set the minimum in STAGENET atomic units.
NW_MONERO_RPC=http://127.0.0.1:38082
NW_MONERO_MIN_ATOMIC=10000000000
# Do NOT set NW_MOCK_PAID* on staging — use the real stagenet watcher above.

# --- Cards: Paddle SANDBOX -------------------------------------------------
# Wire the card rail to Paddle's sandbox; use the sandbox webhook signing secret (mounted/di via env
# per env/portal.env.example's card section). Chargeback set path as in prod.
NW_CARD_REVOKED_PATH=/var/lib/nil-portal/card_revoked.log

# --- Security disclosure (staging canonical base) --------------------------
NW_SECURITY_CANONICAL_BASE=https://api-staging.nilvpn.net
NW_SECURITY_CONTACT=mailto:security@nilvpn.net

RUST_LOG=info,nil_portal=info

# monerod (STAGENET) settings consumed by the compose (not nil-portal):
MONEROD_RPC=http://127.0.0.1:38081
MONERO_WALLET_FILE=nil-watch-only-stagenet
# File contents are secret; only this host path belongs in the environment file.
MONERO_WALLET_PASSWORD_FILE=./secrets/monero_wallet_password-staging
