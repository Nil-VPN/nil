# ---------------------------------------------------------------------------
# nil-coordinator — STAGING environment template (local-only; never committed)
# ---------------------------------------------------------------------------
# Same nil-coordinator:prod image + real verifier/grant path as prod. Differs only in hostname, the
# issuer public key it trusts (the STAGING Portal's key), and the staging node registry (the staging
# CVM's real guest-launch measurement, re-pinned on the Coordinator when the node image changes).
# Start from env/coordinator.env.example for the full field docs; below are the staging-specific values.
# ===========================================================================

# Immutable, staging-approved Caddy image. Replace with a verified platform manifest digest.
CADDY_IMAGE=caddy@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST

CTRL_PUBLIC_HOST=ctrl-staging.nilvpn.net
ACME_EMAIL=admin@nilvpn.net

NW_COORDINATOR_ADDR=0.0.0.0:9090
COORDINATOR_NETWORK_SUBNET=172.31.20.0/24
NW_TRUSTED_PROXY_IP=172.31.20.2
COORDINATOR_BACKEND_IP=172.31.20.3
NW_PATH_HOPS=2                       # release posture requires at least entry + exit
NW_NULLIFIER_PATH=/var/lib/nil-coordinator/nullifiers.log
NW_REDEMPTION_RESULT_KEY_FILE=/etc/nil/redemption_result_key.bin # DISTINCT staging raw 32-byte key
NW_GRANT_SIGNING_KEY_FILE=/etc/nil/grant_signing_seed.hex # DISTINCT staging Ed25519 seed; Coordinator only
NW_GRANT_REALM=nil-staging-v1        # identical on staging nodes; never reuse the production realm
NW_GRANT_TTL_SECS=300
# TDX entries require NIL's composite SHA-384 identity plus complete `tdx_policy`; raw MRTD is not
# a valid pin.
NW_NODE_REGISTRY=/etc/nil/registry.json      # staging registry; reviewed identity pinned explicitly

# The STAGING Portal's issuer public key (from the staging Portal's boot log: token_pubkey=...).
# NEVER the prod key — staging and prod issuers are distinct.
# TODO: NW_TOKEN_PUBKEY=<staging portal token_pubkey hex>

RUST_LOG=info,nil_coordinator=info
