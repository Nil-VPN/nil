# Copy to deploy/env/macos-e2e.env (gitignored via *.env), fill in your node's values, then:
#   sudo bash deploy/verify-client-macos.sh <comp-id>
#
# These are node/deployment specifics that don't belong in the committed test script.
NW_NODE_HOST=<node-host-or-ip>
NW_NODE_PORT=443
# The node's attestation measurement the client pins and verifies (96 hex chars).
NW_EXPECTED_MEASUREMENT=<measurement-hex>
