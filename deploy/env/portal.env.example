# ---------------------------------------------------------------------------
# nil-portal (Business plane) — production environment template
# ---------------------------------------------------------------------------
# Copy to deploy/env/portal.env and fill in the TODO values. This file holds
# NON-SECRET configuration only. The issuer private key stays non-extractable in an HSM and its PIN
# is a Docker secret file, never an env value. Do NOT commit the filled-in copy.
#
# This stack is its OWN trust domain: run it on a host/account that is
# SEPARATE from the Coordinator (Control plane). The Portal is the only plane
# that ever touches payment; it never sees a packet and never holds identity
# beyond H(secret) + entitlement.
#
# nil-portal serves PLAIN HTTP. The Caddy reverse proxy in
# compose.portal.yaml terminates TLS for api.<domain>; nil-portal itself is
# never exposed directly to the internet.
# ===========================================================================

# --- Immutable external runtime images ------------------------------------
# The NIL release workflow does not yet publish an approved Caddy or wallet-rpc digest. Resolve
# each image for the deployment platform, verify it, and record it in the signed release manifest.
# These fail-closed placeholders deliberately prevent a mutable-tag deployment.
CADDY_IMAGE=caddy@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST
MONERO_WALLET_RPC_IMAGE=ghcr.io/sethforprivacy/simple-monero-wallet-rpc@sha256:REPLACE_WITH_APPROVED_64_HEX_MANIFEST_DIGEST

# --- Public hostname (proxy / Let's Encrypt) ------------------------------
# TODO: the public FQDN clients hit, e.g. api.nilvpn.example. Caddy obtains a
#       Let's Encrypt certificate for exactly this name. A/AAAA DNS for it must
#       already point at this host before first boot, or ACME will fail.
PORTAL_PUBLIC_HOST=api.example.com
# TODO: contact email for the Let's Encrypt account (expiry notices only).
ACME_EMAIL=admin@example.com

# --- nil-portal HTTP bind (behind the proxy) -------------------------------
# The binary defaults to 127.0.0.1:8080. Inside compose it must bind the
# container's own interface so the proxy can reach it over the internal
# network; the port is NOT published to the host. Keep the port 8080.
NW_PORTAL_ADDR=0.0.0.0:8080

# --- Authenticated reverse-proxy attribution -------------------------------
# The Rust service accepts Caddy's overwritten X-Nil-Client-IP only when the direct socket peer
# equals this exact canonical address. compose.portal.yaml assigns it to Caddy on a private,
# configurable subnet. If the default subnet overlaps the host/VPN network, change all three
# values together before first boot; do not expose nil-portal directly.
PORTAL_NETWORK_SUBNET=172.30.10.0/24
NW_TRUSTED_PROXY_IP=172.30.10.2
PORTAL_BACKEND_IP=172.30.10.3

# --- Durable account store -------------------------------------------------
# PII-minimized: H(secret), auth public key, entitlement, hashed activation/issuance/mint keys,
# encrypted retry payloads, and authoritative mint quota windows. Related outcomes commit in one
# durability boundary; see RETAINED_DATA.md for the exact pseudonymous fields and retention.
# Path INSIDE the container; compose maps it to a named volume. Unset ⇒ the
# accounts and activation outcomes are VOLATILE (dev only). Leave as-is for the
# file-backed default.
NW_PORTAL_STORE=/var/lib/nil-portal/accounts.json
#
# Clustered alternative (OFF by default): a Postgres-backed account store.
# Only honoured when nil-portal is BUILT with --features postgres; the default
# image pulls no DB driver and refuses this setting. PgStore::connect() uses NoTls and
# REFUSES any non-loopback host, so this must be a loopback / unix-socket DSN
# (co-locate Postgres) unless you build a TLS-connected client. Leave UNSET to
# use the file store above.
# NW_PORTAL_PG_URL=postgres://nil@127.0.0.1:5432/nil_portal

# Independent AES-256-GCM key for completed issuance/mint retry payloads. This is NOT the RSA
# signing key. Generate exactly 32 RAW bytes, keep mode 0600, mount it read-only, and use the same
# key on every Portal replica sharing the same file/Postgres Store:
#   openssl rand -out deploy/secrets/portal_result_key.bin 32
#   sudo chown 10001:10001 deploy/secrets/portal_result_key.bin
#   sudo chmod 0400 deploy/secrets/portal_result_key.bin
NW_PORTAL_RESULT_KEY_FILE=/etc/nil/portal_result_key.bin

# --- Privacy Pass HSM issuer (MOST SENSITIVE BOUNDARY) ----------------------
# Production Portal images contain the PKCS#11 backend and reject software/file issuer keys.
# Provision exactly one non-extractable RSA-2048 keypair in the reviewed HSM, with raw RSA
# CKM_RSA_X_509 signing enabled, then set its exact label and numeric token slot below.
NW_TOKEN_HSM_KEY_LABEL=nil-issuer-production
NW_TOKEN_HSM_SLOT=REPLACE_WITH_NUMERIC_HSM_SLOT_ID
# Host path to the approved vendor PKCS#11 module. Its hash, dependencies, platform ABI, and vendor
# provenance must be recorded in the signed release manifest. Compose mounts it read-only at the
# fixed in-container NW_TOKEN_HSM_MODULE path; this must not be SoftHSM in production.
PORTAL_PKCS11_MODULE_FILE=/absolute/path/to/approved/vendor-pkcs11.so
# Host path to the HSM user-PIN file. Store only the PIN (not name=value), owner 10001:10001, mode
# 0400, outside git. Compose mounts it at the fixed NW_TOKEN_HSM_PIN_FILE path. Never set
# NW_TOKEN_HSM_PIN, NW_TOKEN_SECRET_FILE, NW_TOKEN_SECRET, or NW_TOKEN_HSM_PROVISION here.
PORTAL_HSM_PIN_FILE=./secrets/portal_hsm_pin

# --- One-token-per-payment migration fence ---------------------------------
# Read-only legacy spent set. New request-bound completions commit to NW_PORTAL_STORE/Postgres.
# Preserve this file and stop EVERY old Portal instance before starting this version: mixed
# old/new authorities can sign the same paid checkout twice. After completing that stop-the-world
# procedure, set the acknowledgement below to exactly 1. This is intentionally not pre-accepted.
# The supplied image seeds an empty owner-readable file only for a brand-new named volume; custom
# storage layouts must provision the fence explicitly, and upgrades must preserve its old entries.
NW_ISSUED_PATH=/var/lib/nil-portal/issued.log
NW_ISSUANCE_STOP_THE_WORLD_CUTOVER=REPLACE_WITH_1_AFTER_ALL_OLD_PORTALS_ARE_STOPPED

# --- Checkout/subscription replay state (durable) --------------------------
# Portal-minted checkout references and account/reference bindings are timed,
# durable guards. They use the same TTL and are pruned every 300 seconds.
NW_PENDING_PATH=/var/lib/nil-portal/pending.log
NW_SUB_BINDINGS_PATH=/var/lib/nil-portal/subscription-bindings.log
NW_CHECKOUT_TTL_SECS=3600
# Separate checkout admission budget per direct TCP peer per 60 seconds. Behind Caddy the direct
# peer is the proxy, so Caddy/upstream must enforce the real public per-source limit too.
NW_CHECKOUT_RATE_MAX=30
# Atomic hard cap on timed pending references. At/above the cap checkout returns 503 before entropy
# or fsync; TTL pruning must make room before new checkout can resume.
NW_PENDING_MAX_ENTRIES=100000

# READ-ONLY LEGACY MIGRATION FENCE. Atomic Portal versions do not append new
# activations here; NW_PORTAL_STORE/Postgres now commits each activation result
# with the account update. This path is nevertheless REQUIRED by the current
# production build so a rolling upgrade cannot re-extend a pre-upgrade binding.
# Startup opens the file read-only and refuses a missing path. During an upgrade,
# preserve the existing file. The supplied image seeds an empty owner-readable
# file into a brand-new Docker named volume; other volume/orchestrator layouts
# must provision it explicitly before Portal starts. A missing/mistyped path is
# never allowed to silently become an empty fence.
#
# Define T0 as the moment the LAST old Portal instance stopped and all new
# instances were healthy. Keep this file configured, unchanged, for at least:
#   max NW_CHECKOUT_TTL_SECS used during rollout + 600 seconds
# while the binding-prune loop reports no failures. The extra 600 seconds cover
# two 300-second prune intervals (scheduler alignment + rollout/clock margin).
# The current release still requires the path after that eligibility point;
# remove it only with a later release that explicitly drops the requirement.
NW_SUB_ACTIVATED_PATH=/var/lib/nil-portal/subscription-activated-legacy.log

# --- Self-hosted Monero watcher --------------------------------------------
# monero-wallet-rpc is co-located in this stack. The portal service shares the
# wallet-rpc network namespace, so 127.0.0.1 is true loopback for both services.
# nil-portal rejects plaintext non-loopback URLs; keep this loopback unless you
# front a remote wallet-rpc with TLS and use https://.
NW_MONERO_RPC=http://127.0.0.1:18082
# Minimum accepted payment, in ATOMIC units (1 XMR = 1_000_000_000_000). A
# confirmed transfer below this does NOT mint a token (closes underpayment).
# Unset ⇒ accept ANY confirmed amount (dev only).
# TODO: set the per-plan price in atomic units. Example below = 0.01 XMR.
NW_MONERO_MIN_ATOMIC=10000000000
# Dev/integration ONLY: comma-separated payment ids treated as already paid
# WITHOUT a live wallet. Ignored whenever NW_MONERO_RPC is set (above takes
# precedence). Leave UNSET in production.
# NW_MOCK_PAID=

# --- Security disclosure (/.well-known/security.txt, RFC 9116) --------------
# The Portal always serves /.well-known/security.txt. These knobs are optional
# (sensible nilvpn.net defaults apply). No user-linkable data — role contact +
# canonical URLs only (PD-1). The Expires field is recomputed per request, so
# the file never goes stale.
# Contact for responsible disclosure (default: mailto:security@nilvpn.net).
# NW_SECURITY_CONTACT=mailto:security@nilvpn.net
# Canonical base for the Canonical/Encryption/Policy URLs (default https://nilvpn.net).
# Set to the host that actually serves the file (e.g. https://api.nilvpn.net).
# NW_SECURITY_CANONICAL_BASE=https://nilvpn.net
# Path INSIDE the container to the PGP public key served at /.well-known/nil-security.asc.
# When set, an `Encryption:` line advertising it is added to security.txt; when
# unset, that line is omitted (no dead reference) and the .asc path returns 404.
# NW_SECURITY_PGP_KEY_PATH=/etc/nil/security-pgp.asc

# --- Logging ----------------------------------------------------------------
# The checked-in Caddyfile disables HTTP access logs and Compose discards Caddy operational output.
# Portal operational output is bounded by Compose but is not assumed anonymous. Raise verbosity
# only under a time-bounded incident procedure with separate retention and deletion controls.
RUST_LOG=info,nil_portal=info

# ---------------------------------------------------------------------------
# monero-wallet-rpc settings (consumed by compose.portal.yaml, not nil-portal)
# ---------------------------------------------------------------------------
# TODO: a remote monerod (or run your own). The watch-only wallet talks to this
#       daemon. Use a node you trust; a public node sees your wallet's queries.
MONEROD_RPC=http://node.example.org:18081
# TODO: the watch-only wallet filename that already exists in the wallet volume
#       (create it once with monero-wallet-cli using your address + view key).
MONERO_WALLET_FILE=nil-watch-only
# Host path to an owner-only file containing the watch-only wallet password. Compose mounts it as
# /run/secrets/monero_wallet_password and passes only that path to monero-wallet-rpc. Do not put the
# password value in this environment file. Generate it before first start, keep it out of git, and
# verify the approved wallet image's runtime UID can read the rendered secret mount:
#   openssl rand -base64 48 > deploy/secrets/monero_wallet_password
#   chmod 0400 deploy/secrets/monero_wallet_password
MONERO_WALLET_PASSWORD_FILE=./secrets/monero_wallet_password
